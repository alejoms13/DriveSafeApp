rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Colección de prueba pública temporal para el seeder
    match /test/{document} {
      allow read, write: if true;
    }

    // Reglas para usuarios
    match /usuarios/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Reglas para configuraciones
    match /configuraciones/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Reglas para alertas
    match /alertas/{alertaId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.usuarioId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.usuarioId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.usuarioId;
    }
  }
}

